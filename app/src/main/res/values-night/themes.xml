<resources>
<!-- Base application theme. -->
<style name="Base.Theme.MyApplication2222" parent="Theme.Material3.DayNight.NoActionBar">
    <!-- Primary brand color. -->
    <item name="colorPrimary">@color/primary_blue</item>
    <item name="colorOnPrimary">@color/white</item>
    <item name="colorPrimaryContainer">@color/security_slate</item>
    <item name="colorOnPrimaryContainer">@color/surface_blue_tint</item>

    <!-- Secondary brand color. -->
    <item name="colorSecondary">@color/secondary_teal</item>
    <item name="colorOnSecondary">@color/white</item>
    <item name="colorSecondaryContainer">@color/secondary_teal_dark</item>
    <item name="colorOnSecondaryContainer">@color/white</item>

    <!-- Status colors. -->
    <item name="colorError">@color/error_red</item>
    <item name="colorOnError">@color/white</item>
    <item name="colorErrorContainer">@color/error_red_light</item>
    <item name="colorOnErrorContainer">@color/error_red</item>

    <!-- Background and surface colors. -->
    <item name="android:colorBackground">@color/security_navy</item>
    <item name="colorOnBackground">@color/text_on_dark</item>
    <item name="colorSurface">@color/surface_dark</item>
    <item name="colorOnSurface">@color/text_on_dark</item>
    <item name="colorSurfaceVariant">@color/security_slate</item>
    <item name="colorOnSurfaceVariant">@color/text_secondary</item>
    <item name="colorOutline">@color/security_slate</item>
</style>
</resources>