<resources>
<!-- Base application theme. -->
<style name="Base.Theme.MyApplication2222" parent="Theme.Material3.DayNight.NoActionBar">
    <!-- Primary brand color. -->
    <item name="colorPrimary">@color/primary_blue</item>
    <item name="colorOnPrimary">@color/white</item>
    <item name="colorPrimaryContainer">@color/surface_blue_tint</item>
    <item name="colorOnPrimaryContainer">@color/primary_blue_dark</item>

    <!-- Secondary brand color. -->
    <item name="colorSecondary">@color/secondary_teal</item>
    <item name="colorOnSecondary">@color/white</item>
    <item name="colorSecondaryContainer">@color/secondary_teal</item>
    <item name="colorOnSecondaryContainer">@color/white</item>

    <!-- Status colors. -->
    <item name="colorError">@color/error_red</item>
    <item name="colorOnError">@color/white</item>
    <item name="colorErrorContainer">@color/error_red_light</item>
    <item name="colorOnErrorContainer">@color/error_red</item>

    <!-- Background and surface colors. -->
    <item name="android:colorBackground">@color/background_light</item>
    <item name="colorOnBackground">@color/text_primary</item>
    <item name="colorSurface">@color/surface_white</item>
    <item name="colorOnSurface">@color/text_primary</item>
    <item name="colorSurfaceVariant">@color/surface_blue_tint</item>
    <item name="colorOnSurfaceVariant">@color/text_secondary</item>
    <item name="colorOutline">@color/border_light</item>
</style>

<style name="Theme.MyApplication2222" parent="Base.Theme.MyApplication2222" />

<style name="CircularButton" parent="Widget.Material3.Button">
    <item name="android:layout_width">150dp</item>
    <item name="android:layout_height">150dp</item>
    <item name="cornerRadius">75dp</item>
    <item name="iconSize">50dp</item>
    <item name="android:textColor">@android:color/white</item>
</style>
</resources>